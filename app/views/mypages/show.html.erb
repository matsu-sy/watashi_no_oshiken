<% content_for :page_title, t(".title") %>

<div class="mx-auto w-full max-w-2xl px-4 pb-4 sm:pb-6">
  <!-- プロフィールカード -->
  <section class="rounded-2xl border border-slate-200 bg-white shadow-sm">
    <!-- カードヘッダー：プロフィール + 編集 -->
    <div class="relative flex items-center justify-end px-6 py-6 sm:px-8 sm:pt-8">
      <h2 class="absolute left-1/2 -translate-x-1/2 text-base font-semibold text-[#5B5652]"><%= t(".profile") %></h2>

      <%= link_to edit_mypage_path(@user),
        class: "inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
            stroke-width="1.8" stroke="currentColor" class="h-4 w-4 text-slate-600">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M16.862 4.487 19.5 7.125m-2.638-2.638L7.5 13.85V16.5h2.65l9.712-9.375ZM6 20.25h12.75" />
        </svg>
        <span><%= t(".edit") %></span>
      <% end %>
    </div>

    <div class="px-8 pb-8 sm:px-10 sm:pb-10">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-[100px,1fr] sm:gap-6">
        <!-- 左：画像 -->
        <div class="flex items-start justify-center">
          <%= render "shared/avatar", user: @user, size_class: "h-20 w-20", variant_px: 240 %>
        </div>

        <!-- 右：情報 -->
        <div class="space-y-4">
          <!-- 名前 -->
          <div class="rounded-2xl bg-slate-50 px-3 py-4 ring-1 ring-black/5">
            <div class="grid grid-cols-[100px,1fr] items-start gap-4">
              <div class="h-8 flex items-center justify-center">
                <p class="text-xs font-medium text-slate-500"><%= t(".name") %></p>
              </div> 
                <p class="text-lg sm:text-xl font-semibold text-slate-800">
                  <%= @user.name %>
                </p>
            </div>
          </div>

          <!-- 出身地 -->
          <div class="rounded-2xl bg-slate-50 px-3 py-4 ring-1 ring-black/5">
            <div class="grid grid-cols-[100px,1fr] items-start gap-4">
              <div class="flex flex-col gap-2">
                <!-- 出身地 -->
                <div class="h-8 flex items-center justify-center">
                  <p class="text-xs font-medium text-slate-500"><%= t(".hometown") %></p>
                </div>

                <!-- 公開設定 -->
                <div class="h-8 flex items-center justify-center">
                  <span class="inline-flex items-center justify-center rounded-full border px-2.5 py-1 text-xs font-medium whitespace-nowrap
                              <%= @user.hometown_visibility ? 'border-[#92B099]/40 text-[#5F7F69] bg-[#92B099]/10' : 'border-slate-200 text-slate-500 bg-white' %>">
                    <%= @user.hometown_visibility ? t(".visible") : t(".hidden") %>
                  </span>
                </div>
              </div>

              <!-- 出身県 -->
              <div class="min-h-[72px] flex flex-wrap items-center gap-2">
                <% hometowns = @hometowns.order(:created_at).limit(3) %>
                <% hometowns += [nil] * (3 - hometowns.size) %>

                <% hometowns.each do |h| %>
                  <% name = h&.prefecture&.name %>
                  <% is_set = name.present? %>

                  <span
                    class="inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-medium ring-1
                          <%= if is_set
                                'bg-white text-[#5F7F69] ring-[#92B099]'
                              else
                                'bg-white text-slate-400 ring-slate-200'
                              end %>">
                    <%= name.presence || "未設定" %>
                  </span>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<!-- 獲得したバッヂ -->
<% prefecture_badges = @badges.map { |badge| badge.post.prefecture_code }.uniq %>

<div class="mx-auto w-full max-w-5xl px-4 pb-8 sm:pb-10">
  <section class="mt-10">
    <h2 class="pb-6 text-base font-semibold text-[#5B5652] text-center">
      <%= t(".badges") %>
    </h2>

    <% if prefecture_badges.any? %>
      <div class="flex flex-wrap justify-center gap-3">
        <% prefecture_badges.each do |prefecture_code| %>
          <% prefecture = JpPrefecture::Prefecture.find(code: prefecture_code) %>
          <span class="inline-flex items-center justify-center rounded-full bg-amber-300 px-8 py-2 text-lg font-medium text-[#8A5A00] gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
              <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321 1.01l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.386a.562.562 0 0 1-.84.61l-4.725-2.885a.563.563 0 0 0-.586 0L6.98 20.56a.562.562 0 0 1-.84-.61l1.285-5.386a.563.563 0 0 0-.182-.557L3.04 10.407a.562.562 0 0 1 .321-1.01l5.518-.442a.563.563 0 0 0 .475-.345l2.125-5.11Z"/>
            </svg>
            <%= prefecture.name %>
          </span>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-slate-500 text-center">
        <%= t(".badges_empty") %>
      </p>
    <% end %>
  </section>
</div>

<!-- リアクションした投稿 -->
<div class="mx-auto w-full max-w-5xl px-4 pb-12">
  <section class="mt-10">
    <h2 class="pb-6 text-base font-semibold text-[#5B5652] text-center">
      <%= t(".reacted_posts") %>
    </h2>

    <% if @reacted_posts.present? %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <%= render @reacted_posts %>
      </div>
    <% else %>
      <p class="text-sm text-slate-500 text-center">
        <%= t(".reacted_posts_empty") %>
      </p>
    <% end %>
  </section>
</div>