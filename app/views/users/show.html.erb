<% content_for :page_title, t(".title") %>

<div class="mx-auto w-full max-w-2xl px-4 pb-10 sm:pb-12">
  <section class="rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="px-6 py-6 sm:px-8 sm:pt-8">
      <h2 class="text-base font-semibold text-[#5B5652] text-center">
        <%= t(".profile") %>
      </h2>
    </div>

    <div class="px-8 pb-8 sm:px-10 sm:pb-10">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-[100px,1fr] sm:gap-6">
        <div class="flex items-start justify-center">
          <%= render "shared/avatar", user: @user, size_class: "h-20 w-20", variant_px: 240 %>
        </div>

        <div class="space-y-4">
          <div class="rounded-2xl bg-slate-50 px-3 py-4 ring-1 ring-black/5">
            <div class="grid grid-cols-[100px,1fr] items-start gap-4">
              <div class="h-8 flex items-center justify-center">
                <p class="text-xs font-medium text-slate-500"><%= t(".name") %></p>
              </div>
              <p class="text-lg font-semibold text-slate-800 sm:text-xl">
                <%= @user.name %>
              </p>
            </div>
          </div>

          <div class="rounded-2xl bg-slate-50 px-3 py-4 ring-1 ring-black/5">
            <div class="grid grid-cols-[100px,1fr] items-start gap-4">
              <div class="flex flex-col gap-2">
                <div class="h-8 flex items-center justify-center">
                  <p class="text-xs font-medium text-slate-500"><%= t(".hometown") %></p>
                </div>

                <div class="h-8 flex items-center justify-center">
                  <span class="inline-flex items-center justify-center rounded-full border px-2.5 py-1 text-xs font-medium whitespace-nowrap
                              <%= @user.hometown_visibility? ? 'border-[#92B099]/40 text-[#5F7F69] bg-[#92B099]/10' : 'border-slate-200 text-slate-500 bg-white' %>">
                    <%= @user.hometown_visibility? ? t(".visible") : t(".hidden") %>
                  </span>
                </div>
              </div>

              <div class="min-h-[72px] flex flex-wrap items-center gap-2">
                <% if @user.hometown_visibility? %>
                  <% @user.public_hometowns.each do |hometown| %>
                    <span class="inline-flex items-center justify-center rounded-full bg-white px-4 py-2 text-sm font-medium text-[#5F7F69] ring-1 ring-[#92B099]">
                      <%= hometown.prefecture.name %>
                    </span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
