<%# locals: title:, subtitle: (optional) %>
<section class="bg-[#E9E6DF]">
  <div class="mx-auto max-w-2xl px-4 py-10 text-center">

    <h1 class="text-xl sm:text-2xl font-semibold tracking-[0.2em] text-[#5B5652]">
      <%= title %>
    </h1>

    <div class="mx-auto mt-2 h-[2px] w-9 rounded-full bg-[#92B099]/70"></div>

    <% if local_assigns[:subtitle].present? %>
      <p class="mt-4 text-sm leading-7 text-[#6B655F]">
        <%= subtitle %>
      </p>
    <% end %>

  </div>
</section>