<%# app/views/shared/_icon.html.erb %>
<%# locals: name:, icon_class: "" %>

<% icon_class = local_assigns[:icon_class] || "" %>

<% case name.to_s %>
<% when "edit" %>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
       class="<%= icon_class %>" aria-hidden="true">
    <path d="M12 20h9"/>
    <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/>
  </svg>

<% when "unknown" %>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
       class="<%= icon_class %>" aria-hidden="true">
    <path d="M9 18h6"/>
    <path d="M10 22h4"/>
    <path d="M12 2a7 7 0 0 0-4 12c.7.6 1 1.4 1 2h6c0-.6.3-1.4 1-2A7 7 0 0 0 12 2z"/>
  </svg>

<% when "like" %>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
       class="<%= icon_class %>" aria-hidden="true">
    <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/>
  </svg>

<% when "wantgo" %>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
       class="<%= icon_class %>" aria-hidden="true">
    <path d="M12 21c-4.5-4.5-7-7.6-7-11a7 7 0 1 1 14 0c0 3.4-2.5 6.5-7 11z"/>
    <circle cx="12" cy="10" r="3"/>
  </svg>
<% end %>