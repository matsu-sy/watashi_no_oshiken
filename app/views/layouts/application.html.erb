<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : t("defaults.title") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    <%= favicon_link_tag "favicon.png", rel: "apple-touch-icon" %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Zen+Maru+Gothic:wght@500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="m-0 min-h-screen pt-16 font-sans bg-[#FFFEF9] text-[#5B5652]">
    <%= render 'shared/header' %>

    <%# ページタイトル帯 %>
    <% if content_for?(:page_title) %>
      <%= render "shared/page_header", title: yield(:page_title), subtitle: content_for?(:page_subtitle) ? yield(:page_subtitle) : nil %>
    <% end %>

    <main>
      <% if content_for?(:full_bleed) %>
        <div class="pt-4 px-4 sm:px-36">
          <%= render "shared/flash_message" %>
        </div>
        <%= yield %>
      <% else %>
        <%= render "shared/page_container" do %>
          <%= render 'shared/flash_message' %>
          <%= yield %>
        <% end %>
      <% end %>
    </main>

    <%= render 'shared/footer' %>
  </body>
</html>