<article class="relative group flex flex-col overflow-hidden rounded-2xl
                border border-slate-200/80 bg-white
                shadow-[0_10px_30px_rgba(15,23,42,0.05)]
                transition hover:border-slate-300 hover:shadow-[0_14px_40px_rgba(15,23,42,0.07)]
                hover:-translate-y-0.5">

  <%= link_to post_path(post), class: "absolute inset-0 z-0", aria: { label: "#{post.prefecture_name}の#{post.category.name}の詳細を見る" } do %>
  <% end %>

  <div class="relative z-10">
    <% unless user_signed_in? %>
      <!-- カード全体ホバーで表示 -->
      <div class="pointer-events-none absolute left-1/2 -translate-x-1/2 top-full z-20 mt-2
                  opacity-0 transition-opacity
                  group-hover:opacity-100">
        <div class="relative rounded-md bg-slate-900/90 px-3 py-1.5 text-xs text-white shadow">
          <%= t("posts.index.login_required_tooltip") %>
          <!-- ヘッダーに向く三角 -->
          <span class="absolute -top-1 left-10 h-2 w-2 rotate-45 bg-slate-900/90"></span>
        </div>
      </div>
    <% end %>

    <!-- 県 / カテゴリ -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
      <div class="flex items-center gap-1.5 text-[#5F7F69]">
        <% if post.badges.any? %>
          <%= render "shared/icon", name: "star", icon_class: "h-4 w-4 text-amber-500 shrink-0" %>
        <% end %>
        <span class="text-sm font-bold tracking-tight"><%= post.prefecture_name %></span>
        <span class="text-[10px] text-slate-500">の</span>
        <span class="text-xs font-medium text-slate-500"><%= post.category.name %></span>
      </div>

      <%= render "shared/icon",
        name: "circle-arrow-right",
        icon_class: "ml-3 h-7 w-7 shrink-0 text-[#92B099] transition group-hover:text-[#5F7F69]" %>
    </div>
  </div>

  <div class="flex flex-1 flex-col gap-3 p-5">
    <!-- ユーザー -->
    <div class="flex items-center gap-3">
      <%= link_to user_path(post.user), class: "relative z-10" do %>
        <%= render "shared/avatar", user: post.user, size_class: "h-12 w-12", variant_px: 96 %>
      <% end %>

      <div class="min-w-0">
        <p class="truncate text-sm font-semibold text-slate-700">
          <%= post.user.name %>
        </p>
      </div>
    </div>

    <!-- 本文 -->
    <%
      clamp_class =
        if post.image.attached? && post.place_name.present?
          "line-clamp-1"
        elsif post.image.attached?
          "line-clamp-2"
        else
          "line-clamp-5"
        end
    %>

    <p class="text-sm leading-relaxed text-slate-700 <%= clamp_class %> min-h-0">
      <%= post.body %>
    </p>

    <!-- 画像 -->
    <% if post.image.attached? || post.place_name.present? %>
      <div class="space-y-2">
        <% if post.image.attached? %>
          <div class="h-24 overflow-hidden rounded-xl bg-slate-100">
            <%= image_tag post.image_index, class: "h-auto w-full object-contain" %>
          </div>
        <% end %>

        <% if post.place_name.present? %>
          <div class="flex items-center gap-1.5 min-w-0 text-xs text-slate-400">
            <%= render "shared/icon", name: :map_pin, icon_class: "h-4 w-4 fill-current opacity-80" %>
            <span class="truncate"><%= post.place_name %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- リアクション -->
    <div class="relative z-10 mt-auto border-t border-slate-100 pt-3 flex items-center justify-between">
      <%= render "posts/reactions", post: post %>
      <span class="text-xs text-slate-500"><%= post.created_at.strftime("%m/%d %H:%M") %></span>
    </div>
  </div>
</article>