<% content_for :page_title, t("posts.show.title") %>

<div class="mx-auto w-full max-w-2xl px-4 px-4 pb-8 sm:pb-10">
  <!-- 戻る -->
  <div class="mb-2">
    <%= link_to posts_path, class: "inline-flex items-center gap-2 text-sm text-slate-600 hover:text-slate-900" do %>
      <span aria-hidden="true">‹</span>
      一覧に戻る
    <% end %>
  </div>

  <!-- 投稿詳細 -->
  <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="flex w-full items-center justify-between bg-[#92B099] px-5 py-3 text-base text-white">
      <!-- 県 / カテゴリ -->
      <div class="flex items-center gap-2">
        <span class="font-semibold"><%= @post.prefecture_name %></span>
        <span class="mx-2 text-base text-white/90">の</span>
        <span class="font-semibold"><%= @post.category.name %></span>
      </div> 
      <!-- 編集 -->
      <div>
        <% if current_user.own?(@post) %>
          <%= link_to edit_post_path(@post),
              class: "ml-auto inline-flex h-8 w-8 items-center justify-center rounded-full
                      bg-white/10 text-white hover:bg-white/20
                      focus:outline-none focus:ring-2 focus:ring-white/40" do %>
          <%= render "shared/icon",
                name: :edit,
                icon_class: "h-4 w-4 fill-none stroke-current stroke-2" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="flex flex-col gap-5 p-8 sm:p-10">
      <!-- ユーザー -->
      <div class="flex items-center gap-3">
        <div class="h-12 w-12 rounded-full bg-slate-200"></div>

        <div class="min-w-0">
          <p class="truncate text-sm font-semibold text-slate-700">
            <%= @post.user.name %>
          </p>
          <% if @post.place_name.present? %>
            <p class="text-xs text-slate-500"><%= @post.place_name %></p>
          <% end %>
        </div>
      </div>

      <!-- 本文 -->
      <div class="text-base leading-relaxed text-slate-700">
        <%= @post.body %>
      </div>

      <!-- 画像-->
      <% if @post.image.attached? %>
        <div class="overflow-hidden rounded-2xl bg-slate-100 ">
          <%= image_tag @post.image_show,
                class: "w-full object-contain bg-slate-100" %>
        </div>
      <% end %>

      <!-- リアクション -->
      <div class="flex items-center justify-between border-t border-slate-100 pt-4">
        <%= render "posts/reactions", post: @post %>

        <span class="text-xs text-slate-500">
          <%= @post.created_at.strftime("%Y/%m/%d %H:%M") %>
        </span>
      </div>
    </div>
  </article>

  <!-- コメント（仮） -->
  <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-sm font-semibold text-slate-800">コメント</h2>
    <p class="mt-3 text-sm text-slate-500">※MVPでは後で追加</p>
  </section>
</div>
