<% content_for :page_title, t("posts.show.title") %>

<div class="mx-auto w-full max-w-2xl px-4 pb-8 sm:pb-10">
  <!-- 戻る -->
  <div class="mb-2">
    <%= link_to posts_path, class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-800" do %>
      <span aria-hidden="true">‹</span>
      <%= t(".back_to_list") %>
    <% end %>
  </div>

  <!-- 投稿詳細 -->
  <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="flex w-full items-center justify-between px-5 py-4 border-b border-slate-100">
      <!-- 県 / カテゴリ -->
      <div class="flex items-center gap-2 min-w-0">
        <% if @post.badges.any? %>
          <%= render "shared/icon", name: "star", icon_class: "h-5 w-5 text-amber-500 shrink-0" %>
        <% end %>
        <span class="font-semibold text-[#5F7F69] truncate"><%= @post.prefecture_name %></span>
        <span class="text-sm text-slate-400">の</span>
        <span class="font-medium text-slate-500 truncate"><%= @post.category.name %></span>
      </div>
      <!-- 編集 -->
      <div>
        <% if current_user.own?(@post) %>
          <%= link_to edit_post_path(@post),
            class: "inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2
                    text-sm font-medium text-slate-600 hover:bg-slate-50 hover:text-slate-900" do %>
            <%= render "shared/icon", name: :edit, icon_class: "h-4 w-4 fill-none stroke-current" %>
            <span><%= t(".edit") %></span>
          <% end %>
        <% end %>
      </div>
    </div>

        <% if @post.badges.any? %>
    <div class="px-5 pt-4">
      <div class="rounded-xl bg-amber-50 px-4 py-3 ring-1 ring-amber-100">
        <div class="flex items-start gap-2">
          <%= render "shared/icon", name: "star", icon_class: "h-4 w-4 text-amber-500 shrink-0 mt-0.5" %>
          <p class="text-xs leading-5 text-amber-800">
            <%= t(".star_description") %>
          </p>
        </div>
      </div>
    </div>
  <% end %>

    <div class="flex flex-col gap-5 p-8 sm:p-10">
      <!-- ユーザー -->
      <div class="flex items-center gap-3">
        <%= link_to user_path(@post.user) do %>
          <%= render "shared/avatar", user: @post.user, size_class: "h-12 w-12", variant_px: 96 %>
        <% end %>

        <div class="min-w-0">
          <p class="truncate text-sm font-semibold text-slate-700">
            <%= @post.user.name %>
          </p>
        </div>
      </div>

      <!-- 本文 -->
      <div class="text-sm sm:text-base leading-relaxed text-slate-700">
        <%= @post.body %>
      </div>

      <!-- 画像-->
      <% if @post.image.attached? %>
        <div class="overflow-hidden rounded-xl bg-slate-100 ">
          <%= image_tag @post.image_show,
                class: "w-full object-contain bg-slate-100" %>
        </div>
      <% end %>

      <!-- 場所名 -->
      <% if @post.place_name.present? %>
        <div class="flex items-center gap-1.5 text-sm text-slate-400">
          <%= render "shared/icon", name: :map_pin, icon_class: "h-4 w-4 fill-current opacity-80" %>
          <span class="truncate"><%= @post.place_name %></span>
        </div>
      <% end %>

      <!-- リアクション -->
      <div class="flex items-center justify-between border-t border-slate-100 pt-4">
        <%= render "posts/reactions", post: @post %>

        <span class="text-xs text-slate-500">
          <%= @post.created_at.strftime("%Y/%m/%d %H:%M") %>
        </span>
      </div>
    </div>
  </article>

  <%# 
    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-sm font-semibold text-slate-800">コメント</h2>
      <p class="mt-3 text-sm text-slate-500">※MVPでは後で追加</p>
    </section>
  %>
</div>
