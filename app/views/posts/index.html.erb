<% content_for :page_title, t(".title") %>
<% content_for :page_subtitle, t(".subtitle") %>

<% if user_signed_in? %>
  <div class="mx-auto flex justify-center gap-10 mb-10">
    <%= link_to t(".tabs.hometown"),
        posts_path(filter: "hometown"),
        class: "block min-w-[220px] text-center pb-2 border-b text-[#5B5652] " +
              (@current_filter == "hometown" ? "border-[#92B099] border-b-2 font-semibold" : "border-slate-200") %>

    <%= link_to t(".tabs.all"),
        posts_path(filter: "all"),
        class: "block min-w-[220px] text-center pb-2 border-b text-[#5B5652] " +
              (@current_filter == "all" ? "border-[#92B099] border-b-2 font-semibold" : "border-slate-200") %>
  </div>
<% end %>

<% if @current_filter == "hometown" && @hometown_not_registered %>
  <div class="mx-auto max-w-xl rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
    <p class="my-6 text-base sm:text-base font-semibold text-[#5B5652]">
      <%= t(".hometown_prompt.title") %>
    </p>
    <p class="mt-4 text-sm text-[#5B5652]/70">
      <%= t(".hometown_prompt.description") %>
    </p>

    <div class="my-6">
      <%= link_to t(".hometown_prompt.cta"), edit_mypage_path,
        class: "inline-flex items-center justify-center rounded-xl bg-[#92B099] px-4 py-2 text-sm font-medium text-white hover:bg-[#7FA58E]" %>
    </div>
  </div>

<% elsif @posts.present? %>
  <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <%= render @posts %>
  </div>

<% else %>
  <p class="mt-12 text-center text-sm text-slate-500">
    <%= t(".empty") %>
  </p>
<% end %>
