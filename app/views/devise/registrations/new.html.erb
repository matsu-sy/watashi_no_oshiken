<% content_for :page_title, t(".title") %>

<div class="mx-auto w-full max-w-md px-4 pb-10 sm:pb-12">
  <section class="rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="px-6 py-6 sm:px-8">

      <div class="mt-5">
        <%= render "devise/shared/error_messages", resource: resource %>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), data: { turbo: false }, html: { class: "mt-4 space-y-5" }) do |f| %>
        <div class="space-y-1">
          <%= f.label :name, class: "block text-sm font-medium text-[#5B5652]" %>
          <%= f.text_field :name,
                autofocus: true,
                autocomplete: "name",
                class: "block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 placeholder:text-slate-400 shadow-sm focus:border-[#92B099] focus:ring-2 focus:ring-[#92B099]/35" %>
        </div>

        <div class="space-y-1">
          <%= f.label :email, class: "block text-sm font-medium text-[#5B5652]" %>
          <%= f.email_field :email,
                autocomplete: "email",
                class: "block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 placeholder:text-slate-400 shadow-sm focus:border-[#92B099] focus:ring-2 focus:ring-[#92B099]/35" %>
        </div>

        <div class="space-y-1">
          <div class="flex items-baseline justify-between gap-3">
            <%= f.label :password, class: "block text-sm font-medium text-[#5B5652]" %>
            <% if @minimum_password_length %>
              <span class="text-xs text-slate-500">
                <%= t("errors.messages.too_short", count: @minimum_password_length) %>
              </span>
            <% end %>
          </div>
          <%= f.password_field :password,
                autocomplete: "new-password",
                class: "block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 placeholder:text-slate-400 shadow-sm focus:border-[#92B099] focus:ring-2 focus:ring-[#92B099]/35" %>
        </div>

        <div class="space-y-1">
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-[#5B5652]" %>
          <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                class: "block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-800 placeholder:text-slate-400 shadow-sm focus:border-[#92B099] focus:ring-2 focus:ring-[#92B099]/35" %>
        </div>

        <div class="pt-1">
          <%= f.submit t(".submit"),
                class: "inline-flex w-full items-center justify-center rounded-xl bg-[#92B099] px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-[#7FA08B] focus:outline-none focus:ring-2 focus:ring-[#92B099]/40" %>
        </div>
      <% end %>

      <div class="mt-6 border-t border-slate-100 pt-5 text-center text-sm text-slate-600">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </section>
</div>
